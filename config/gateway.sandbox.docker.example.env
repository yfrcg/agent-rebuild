GATEWAY_SANDBOX_ENABLED=true
GATEWAY_SANDBOX_BACKEND=docker
GATEWAY_SANDBOX_MOCK=false
GATEWAY_SANDBOX_REQUIRE_RUNTIME=false
GATEWAY_SANDBOX_MODE=untrusted
GATEWAY_SANDBOX_SCOPE=call
GATEWAY_SANDBOX_DEFAULT_IMAGE=node:20-bookworm-slim
GATEWAY_SANDBOX_NETWORK=none
GATEWAY_SANDBOX_WORKSPACE_ACCESS=copy
GATEWAY_SANDBOX_TIMEOUT_MS=30000
GATEWAY_SANDBOX_MEMORY_LIMIT=512m
GATEWAY_SANDBOX_CPU_LIMIT=1
GATEWAY_SANDBOX_PIDS_LIMIT=128
GATEWAY_SANDBOX_MAX_OUTPUT_BYTES=1048576
GATEWAY_SANDBOX_AUDIT_LOG_PATH=logs/sandbox-audit.jsonl
