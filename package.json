{
  "name": "agent-rebuild",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "dev": "tsx apps/gateway/src/main.ts",
    "reindex": "tsx scripts/reindex.ts",
    "build": "tsc",
    "test": "tsx scripts/run-tests.ts",
    "test:smoke": "node --import tsx --test tests/autoToolLoop.test.ts",
    "backfill:embeddings": "tsx scripts/backfill-embeddings.ts",
    "scheduler": "tsx scripts/scheduler.ts",
    "gateway": "tsx apps/gateway/src/main.ts",
    "gateway:ws": "tsx apps/gateway/src/ws-main.ts",
    "web:dev": "npm --prefix apps/web-ui run dev",
    "web:build": "npm --prefix apps/web-ui run build",
    "gateway:smoke:ws": "tsx scripts/smoke-ws.ts",
    "gateway:smoke": "tsx scripts/smoke-gateway.ts",
    "typecheck": "tsc --noEmit",
    "gateway:smoke:memory-failure": "tsx scripts/smoke-gateway-memory-failure.ts",
    "gateway:smoke:model-failure": "tsx scripts/smoke-gateway-model-failure.ts",
    "gateway:smoke:all": "tsx scripts/smoke-gateway-all.ts",
    "gateway:detect": "tsx scripts/system-detect-offline.ts",
    "gateway:detect:live": "tsx scripts/system-detect.ts",
    "gateway:eval:auto-tool": "tsx scripts/eval-auto-tool.ts",
    "gateway:check": "npm run typecheck && npm run build && npm run test && npm run gateway:smoke:all && npm run gateway:detect",
    "gateway:check:live": "npm run gateway:check && npm run gateway:detect:live"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "ws": "^8.20.0"
  }
}
