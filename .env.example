GATEWAY_MODEL=deepseek
GATEWAY_MEMORY_TOP_K=5
GATEWAY_AUDIT_LOG_PATH=logs/audit/gateway-audit.jsonl
GATEWAY_DEBUG=true

WINDOWS_PROJECT_ROOT=D:\WorkStation\agent-rebuild
WORKSPACE_ROOT=D:\WorkStation\agent-rebuild\workspace
GATEWAY_SANDBOX_ALLOWED_ROOTS=D:\WorkStation\agent-rebuild;D:\WorkStation\agent-rebuild\workspace

# Gateway runtime
GATEWAY_SANDBOX_MODE=off
GATEWAY_CONFIRM_TOKEN_TTL_MS=300000
GATEWAY_AUTO_TOOL_LOOP_ENABLED=true
GATEWAY_AUTO_TOOL_LOOP_MAX_STEPS=5
GATEWAY_DEV_TASK_MAX_STEPS=15
GATEWAY_DEV_TASK_MAX_FIX_ROUNDS=3
GATEWAY_SESSION_AUTO_COMPACT_ENABLED=true
GATEWAY_SESSION_AUTO_COMPACT_MAX_ENTRIES=80
GATEWAY_RATE_LIMIT_MAX_REQUESTS=30
GATEWAY_RATE_LIMIT_WINDOW_MS=60000
GATEWAY_CIRCUIT_FAILURE_THRESHOLD=3
GATEWAY_CIRCUIT_COOLDOWN_MS=30000
GATEWAY_SLO_MAX_RT_MS=200
GATEWAY_SLO_MAX_ERROR_RATE=0.1

# WebSocket server
GATEWAY_WS_HOST=127.0.0.1
GATEWAY_WS_PORT=8787
GATEWAY_WS_TOKEN=
GATEWAY_WS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GATEWAY_WS_MAX_CONNECTIONS=20
GATEWAY_WS_MAX_MESSAGE_BYTES=1048576
GATEWAY_WS_MAX_RUNS_PER_CLIENT=2
GATEWAY_WS_MAX_RUNS_TOTAL=8
GATEWAY_WS_RATE_LIMIT_WINDOW_MS=60000
GATEWAY_WS_RATE_LIMIT_MAX_MESSAGES=120
GATEWAY_WS_MAX_BUFFERED_AMOUNT=8388608
GATEWAY_WS_MAX_PENDING_EVENTS=1000
GATEWAY_WS_DELTA_BATCH_MS=50
GATEWAY_WS_SHUTDOWN_TIMEOUT_MS=10000

# Model settings
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MAX_TOKENS=1024
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_TIMEOUT_MS=30000

# Embedding settings
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBED_MODEL=text-embedding-v4
DASHSCOPE_EMBED_DIMENSIONS=1024

# Web search (Tavily)
TAVILY_API_KEY=
